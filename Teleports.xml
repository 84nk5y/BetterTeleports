<Ui xmlns="http://www.blizzard.com/wow/ui/"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://www.blizzard.com/wow/ui/ ..\FrameXML\UI.xsd">
    <Script file="Teleports.lua"/>

    <Frame name="HorizontalLayoutFrameTemplate" inherits="HorizontalLayoutFrame" virtual="true">
        <KeyValues>
            <KeyValue key="layoutIndex" value="1" type="number"/>
        </KeyValues>
    </Frame>

    <Button parentKey="TeleportTab" parent="QuestMapFrame" inherits="QuestLogTabButtonTemplate" id="5" mixin="TeleportTabMixin">
        <KeyValues>
            <KeyValue key="displayMode" value="5" type="number"/>
            <KeyValue key="activeAtlas" value="Raid" type="string"/>
            <KeyValue key="inactiveAtlas" value="Raid" type="string"/>
            <KeyValue key="tooltipText" value="Teleports" type="string"/>
        </KeyValues>
        <Anchors>
            <Anchor point="TOP" relativeKey="$parent.MapLegendTab" relativePoint="BOTTOM" x="0" y="-3"/>
        </Anchors>
        <Scripts>
            <OnLoad method="OnLoad"/>
            <OnClick method="OnClick"/>
        </Scripts>
    </Button>

    <Frame parentKey="TeleportPanel" parentArray="ContentFrames" parent="QuestMapFrame" hidden="true" enableMouse="true" mixin="TeleportPanelMixin">
        <KeyValues>
            <KeyValue key="displayMode" value="5" type="number"/>
        </KeyValues>
        <Anchors>
            <Anchor point="TOPLEFT" relativeKey="$parent.ContentsAnchor" y="-29"/>
            <Anchor point="BOTTOMRIGHT" relativeKey="$parent.ContentsAnchor" x="-22"/>
        </Anchors>
        <Frames>
            <Frame parentKey="BorderFrame" inherits="QuestLogBorderFrameTemplate"/>
            <ScrollFrame parentKey="ScrollFrame" inherits="ScrollFrameTemplate">
                <KeyValues>
                    <KeyValue key="scrollBarX" value="8" type="number"/>
                    <KeyValue key="scrollBarTopY" value="2" type="number"/>
                    <KeyValue key="scrollBarBottomY" value="-4" type="number"/>
                </KeyValues>
                <Anchors>
                    <Anchor point="TOPLEFT"/>
                    <Anchor point="BOTTOMRIGHT"/>
                </Anchors>
                <Layers>
                    <Layer level="BACKGROUND">
                        <Texture parentKey="Background" atlas="QuestLog-main-background" useAtlasSize="true">
                            <Anchors>
                                <Anchor point="TOPLEFT"/>
                                <Anchor point="BOTTOMRIGHT"/>
                            </Anchors>
                        </Texture>
                    </Layer>
                </Layers>
                <ScrollChild>
                    <Frame parentKey="ScrollChild" inherits="VerticalLayoutFrame">
                        <KeyValues>
                            <KeyValue key="leftPadding" value="10" type="number"/>
                            <KeyValue key="rightPadding" value="0" type="number"/>
                            <KeyValue key="topPadding" value="12" type="number"/>
                            <KeyValue key="spacing" value="2" type="number"/>
                        </KeyValues>
                    </Frame>
                </ScrollChild>
            </ScrollFrame>
        </Frames>
        <Layers>
            <Layer level="ARTWORK">
                <FontString parentKey="TitleText" inherits="Game15Font_Shadow" wordwrap="false" text="Teleports">
                    <Anchors>
                        <Anchor point="BOTTOM" relativeKey="$parent.BorderFrame" relativePoint="TOP" x="-1" y="3"/>
                    </Anchors>
                </FontString>
            </Layer>
        </Layers>
    </Frame>

    <Button name="TeleportButtonTemplate" inherits="SecureActionButtonTemplate" virtual="true">
        <Size x="40" y="40"/>
        <KeyValues>
            <KeyValue key="layoutIndex" value="1" type="number"/>
        </KeyValues>
        <Layers>
            <Layer level="ARTWORK">
                <Texture parentKey="Icon">
                    <Size x="36" y="36"/>
                    <Anchors>
                        <Anchor point="TOPLEFT" relativeKey="$parent.Border" x="6" y="-3"/>
                        <Anchor point="BOTTOMRIGHT" relativeKey="$parent.Border" x="-3" y="4"/>
                    </Anchors>
                </Texture>
            </Layer>
            <Layer level="OVERLAY" textureSubLevel="1">
                <Texture parentKey="Border" setAllPoints="true" atlas="spellbook-item-iconframe" useAtlasSize="false" texelSnappingBias="0.0" snapToPixelGrid="false"/>
            </Layer>
            <Layer level="OVERLAY" textureSubLevel="2">
                <Texture parentKey="IconHighlight" setAllPoints="true" atlas="spellbook-item-iconframe-hover" useAtlasSize="false" hidden="true" alpha="0.25" alphaMode="ADD" texelSnappingBias="0.0" snapToPixelGrid="false"/>
            </Layer>
        </Layers>
        <Frames>
            <Cooldown parentKey="Cooldown" inherits="CooldownFrameTemplate" drawEdge="false" useParentLevel="true" hideCountdownNumbers="false">
                <Anchors>
                    <Anchor point="TOPLEFT" relativeKey="$parent.Icon" x="2" y="-2"/>
                    <Anchor point="BOTTOMRIGHT" relativeKey="$parent.Icon" x="-2" y="2"/>
                </Anchors>
            </Cooldown>
        </Frames>
    </Button>
</Ui>